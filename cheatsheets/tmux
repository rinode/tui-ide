[prefix]     Ctrl+b               Tmux prefix key
[session]    prefix d             Detach from session
[session]    prefix s             List and switch sessions
[session]    prefix $             Rename current session
[session]    prefix (             Switch to previous session
[session]    prefix )             Switch to next session
[window]     prefix c             Create new window
[window]     prefix ,             Rename current window
[window]     prefix w             List and switch windows
[window]     prefix n             Next window
[window]     prefix p             Previous window
[window]     prefix 0-9           Switch to window by number
[window]     prefix &             Kill window (with confirm)
[pane]       prefix %             Split pane vertically (side by side)
[pane]       prefix "             Split pane horizontally (top/bottom)
[pane]       prefix arrow         Move between panes
[pane]       prefix q             Show pane numbers
[pane]       prefix q 0-9         Jump to pane by number
[pane]       prefix z             Toggle pane zoom (fullscreen)
[pane]       prefix x             Kill pane (with confirm)
[pane]       prefix {             Swap pane with previous
[pane]       prefix }             Swap pane with next
[pane]       prefix Ctrl+arrow    Resize pane
[copy]       prefix [             Enter copy mode
[copy]       Space                Start selection (in copy mode)
[copy]       Enter                Copy selection (in copy mode)
[copy]       prefix ]             Paste copied text
[copy]       / or ?               Search in copy mode
[misc]       prefix ?             List all keybindings
[misc]       prefix :             Open tmux command prompt
[misc]       prefix t             Show clock
[misc]       prefix /             Open reference menu (custom)
